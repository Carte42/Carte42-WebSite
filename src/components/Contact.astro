---
---

<section id="contact" class="py-24 bg-slate-900/40">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">

    <!-- En-tête -->
    <div class="text-center mb-12 reveal">
      <span class="text-cyan-400 text-sm font-mono tracking-widest uppercase">Contact</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mt-3 mb-4">
        Parlons de votre projet
      </h2>
      <p class="text-slate-400 max-w-lg mx-auto">
        Un besoin en traitement de géodonnées, une question de conformité, un prototype IA à valider ?
        Décrivez-moi votre contexte — je reviens sous 24 h.
      </p>
    </div>

    <!-- Card contact -->
    <div class="reveal reveal-d1 bg-slate-900 border border-slate-800 rounded-2xl p-8 md:p-10">

      <!-- Formulaire -->
      <form
        action="https://formspree.io/f/VOTRE_ID_FORMSPREE"
        method="POST"
        class="space-y-5"
      >
        <!-- NOTE : remplacer VOTRE_ID_FORMSPREE par votre ID formspree.io (compte gratuit) -->

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-300 mb-1.5">Nom</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Votre nom"
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-300 mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="votre@email.fr"
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="organisation" class="block text-sm font-medium text-slate-300 mb-1.5">
            Organisation <span class="text-slate-500 font-normal">(optionnel)</span>
          </label>
          <input
            type="text"
            id="organisation"
            name="organisation"
            placeholder="Collectivité, bureau d'études, entreprise..."
            class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-slate-300 mb-1.5">Votre besoin</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Décrivez votre projet, vos données disponibles, votre contexte..."
            class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-4 bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-semibold rounded-xl transition-all duration-200 hover:scale-[1.01] hover:shadow-lg hover:shadow-cyan-500/20"
        >
          Envoyer le message
        </button>
      </form>

      <!-- Séparateur -->
      <div class="flex items-center gap-4 my-8">
        <div class="flex-1 h-px bg-slate-800"></div>
        <span class="text-slate-600 text-sm">ou</span>
        <div class="flex-1 h-px bg-slate-800"></div>
      </div>

      <!-- Coordonnées directes -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="mailto:contact@carte42.fr"
          class="flex items-center justify-center gap-2.5 px-6 py-3.5 rounded-xl border border-slate-700 hover:border-cyan-500/40 text-slate-300 hover:text-white transition-all duration-200 group"
        >
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" class="text-cyan-500">
            <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          contact@carte42.fr
        </a>
      </div>
    </div>

  </div>
</section>
