---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5">
      <img src="/images/42-256.png" alt="Carte 42" class="w-7 h-7" />
      <span class="font-display font-semibold text-white text-base">
        Carte <span class="text-cyan-400">42</span>
      </span>
    </a>

    <p class="text-slate-500 text-sm text-center">
      © {year} Carte 42 — Tous droits réservés
    </p>

    <!-- Liens réseaux -->
    <div class="flex items-center gap-5">
      <a
        href="mailto:contact@carte42.fr"
        class="text-slate-500 hover:text-cyan-400 text-sm transition-colors"
      >
        contact@carte42.fr
      </a>
      <a
        href="https://www.linkedin.com/company/carte42"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-500 hover:text-cyan-400 transition-colors"
        aria-label="LinkedIn"
      >
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>
