---
const links = [
  { href: '#expertise', label: 'Expertise' },
  { href: '#cas-pratiques', label: 'Cas pratiques' },
  { href: '#a-propos', label: 'À propos' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800/50 bg-slate-950/85 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5">
      <img src="/images/42-256.png" alt="Carte 42" class="w-8 h-8" />
      <span class="font-display font-semibold text-white text-lg tracking-tight">
        Carte <span class="text-cyan-400">42</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-slate-400 hover:text-white text-sm font-medium transition-colors duration-150"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contact"
        class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-sm font-semibold rounded-lg transition-colors duration-150"
      >
        Nous contacter
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-slate-400 hover:text-white transition-colors"
      aria-label="Ouvrir le menu"
    >
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="19" y2="6" />
        <line x1="3" y1="11" x2="19" y2="11" />
        <line x1="3" y1="16" x2="19" y2="16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 bg-slate-950/95">
    <nav class="flex flex-col px-4 py-5 gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-slate-300 hover:text-white text-sm font-medium py-1 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contact"
        class="inline-flex justify-center px-4 py-2.5 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-sm font-semibold rounded-lg transition-colors mt-1"
      >
        Nous contacter
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((link) =>
    link.addEventListener('click', () => menu.classList.add('hidden'))
  );
</script>
