---
const poles = [
  {
    badge: 'Cœur de métier',
    featured: true,
    iconPath: 'M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z',
    title: 'Data Science & IA',
    description:
      "Au cœur de notre activité : des pipelines d'IA sur mesure pour extraire de la valeur de vos données géospatiales massives. De l'ingestion brute à la décision automatisée, nous concevons des workflows intégrant le meilleur du deep learning et des LLMs.",
    items: [
      'Computer Vision & détection d\'objets',
      'LLMs appliqués aux géodonnées',
      'Pipelines de traitement haute performance',
      'Segmentation et classification automatique',
      'Modèles de détection de changements territoriaux',
    ],
  },
  {
    badge: 'Sources massives',
    featured: false,
    iconPath: 'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418',
    title: 'Télédétection',
    description:
      'Maîtrise des sources de géodonnées satellitaires et aériennes. De l\'image brute au produit analytique, nous exploitons le meilleur des capteurs actuels pour la surveillance et l\'analyse du territoire.',
    items: [
      'Satellites THR : Pléiades, SPOT',
      'Copernicus : Sentinel-1, 2, 3',
      'LiDAR HD IGN — nuages de points, MNT/MNS',
      'Indices spectraux : NDVI, NDWI, LAI, NDBI',
      'Détection : canopée, artificialisation, imperméabilisation',
    ],
  },
  {
    badge: 'Acteurs publics',
    featured: false,
    iconPath: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
    title: 'Réglementaire & Institutionnel',
    description:
      "Conformité géospatiale et accompagnement des acteurs publics. Nous maîtrisons les standards nationaux et aidons les collectivités à mettre à jour leurs bases de données dans le respect des obligations réglementaires.",
    items: [
      'Plans Corps de Rue Simplifié (PCRS)',
      'Conformité CNIG et standards IGN',
      'DT-DICT et gestion des réseaux',
      'Mise à jour PLU et documents d\'urbanisme',
      'RGPD et protection des données territoriales',
    ],
  },
];
---

<section id="expertise" class="py-24 bg-slate-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- En-tête de section -->
    <div class="text-center mb-16 reveal">
      <span class="text-cyan-400 text-sm font-mono tracking-widest uppercase">Nos pôles d'expertise</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mt-3 mb-4">
        Trois expertises,<br class="hidden md:block" />
        <span class="text-slate-400 font-medium">un seul interlocuteur</span>
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        De la donnée brute à la décision, nous couvrons toute la chaîne de valeur géospatiale.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {poles.map((pole, i) => (
        <div
          class={`reveal reveal-d${i + 1} card-glow rounded-2xl border p-7 flex flex-col ${
            pole.featured
              ? 'bg-slate-900 border-cyan-500/30 ring-1 ring-cyan-500/20'
              : 'bg-slate-900/60 border-slate-800'
          }`}
        >
          <!-- Badge -->
          <div class="flex items-center justify-between mb-5">
            <span class={`text-xs font-medium px-3 py-1 rounded-full ${
              pole.featured
                ? 'bg-cyan-500/15 text-cyan-400 border border-cyan-500/30'
                : 'bg-slate-800 text-slate-400 border border-slate-700'
            }`}>
              {pole.badge}
            </span>
            {pole.featured && (
              <span class="text-xs text-cyan-500 font-mono">⭐</span>
            )}
          </div>

          <!-- Icône -->
          <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-5 ${
            pole.featured ? 'bg-cyan-500/15 text-cyan-400' : 'bg-slate-800 text-slate-400'
          }`}>
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
              <path d={pole.iconPath} />
            </svg>
          </div>

          <!-- Titre -->
          <h3 class="font-display text-xl font-bold text-white mb-3">{pole.title}</h3>

          <!-- Description -->
          <p class="text-slate-400 text-sm leading-relaxed mb-6">{pole.description}</p>

          <!-- Liste de capacités -->
          <ul class="mt-auto space-y-2">
            {pole.items.map((item) => (
              <li class="flex items-start gap-2 text-sm text-slate-400">
                <svg class="mt-0.5 shrink-0 text-cyan-500" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
