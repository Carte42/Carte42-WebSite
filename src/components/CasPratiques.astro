---
const cas = [
  {
    image: `${import.meta.env.BASE_URL}/images/cases/canopee.png`,
    alt: 'Détection de canopée urbaine par LiDAR HD',
    tags: ['LiDAR HD', 'Computer Vision', 'Python'],
    title: 'Suivi de canopée urbaine',
    description:
      "Détection automatique de l'évolution du couvert arboré et analyse de biodiversité à l'échelle d'un territoire communal. Pipeline complet de classification de nuages de points LiDAR HD.",
  },
  {
    image: `${import.meta.env.BASE_URL}/images/cases/pcrs.png`,
    alt: 'Relevé accessibilité cheminements piétons conforme standard CNIG',
    tags: ['Accessibilité', 'CNIG', 'Voirie'],
    title: 'Accessibilité cheminements — EPCI',
    description:
      "Fourniture du standard CNIG Accessibilité – Voirie et espaces publics (v2021-10) à l'échelle d'un EPCI. Qualification des cheminements piétons autour des points d'arrêt prioritaires, contrôle qualité et livrables SIG directement intégrables.",
  },
  {
    image: `${import.meta.env.BASE_URL}/images/cases/sentinel.png`,
    alt: 'Détection automatisée de changements territoriaux par imagerie multi-canaux',
    tags: ['Copernicus', 'Deep Learning', 'Multi-canaux'],
    title: 'Détection de changements territoire',
    description:
      "Détection automatisée des changements territoriaux à l'échelle d'un département — aménagements, démolitions, évolution de l'occupation du sol — par analyse multitemporelle d'imagerie multi-canaux.",
  },
];
---

<section id="cas-pratiques" class="py-24 bg-slate-900/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- En-tête -->
    <div class="text-center mb-16 reveal">
      <span class="text-cyan-400 text-sm font-mono tracking-widest uppercase">Réalisations</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mt-3 mb-4">
        Cas pratiques
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        Des projets concrets, des résultats mesurables pour des acteurs publics et privés.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cas.map((c, i) => (
        <div class={`reveal reveal-d${i + 1} card-glow rounded-2xl border border-slate-800 bg-slate-900/60 overflow-hidden flex flex-col`}>

          <!-- Image -->
          <div class="aspect-video bg-slate-800 relative overflow-hidden">
            <img
              src={c.image}
              alt={c.alt}
              class="w-full h-full object-cover"
              onerror="this.parentElement.classList.add('flex','items-center','justify-center'); this.style.display='none';"
            />
            <!-- Fallback placeholder si image absente -->
            <div class="absolute inset-0 flex items-center justify-center text-slate-600 text-sm font-mono hidden" id={`placeholder-${i}`}>
              <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" class="opacity-30">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <path d="m21 15-5-5L5 21"/>
              </svg>
            </div>
          </div>

          <!-- Contenu -->
          <div class="p-6 flex flex-col flex-1">
            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-4">
              {c.tags.map((tag) => (
                <span class="text-xs px-2.5 py-1 rounded-md bg-slate-800 text-slate-400 border border-slate-700 font-mono">
                  {tag}
                </span>
              ))}
            </div>
            <h3 class="font-display text-lg font-bold text-white mb-2">{c.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{c.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Note : les images sont à déposer dans public/images/cases/ -->
  </div>
</section>
